@page "/"
@model Chirp.Web.Pages.PublicModel
@{
    ViewData["Title"] = "Chirp!";
    Layout = "Shared/_Layout";
}

<div>
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <form method="post">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div style="color: red; margin-bottom: 10px;">@Model.ErrorMessage</div>
            }
            <textarea asp-for="CheepMessage" required placeholder="Post a Cheep!" rows="4" style="width: 100%; box-sizing: border-box"></textarea>
            <br>
            <input type="submit" value="Post">
        </form>
        <hr>
    }

    <h2> Public Timeline </h2>
    @if (Model.Cheeps.Any())
    {
        <ul id="messagelist" class="cheeps">
            @foreach (var cheep in Model.Cheeps)
            {
                <li>
                    <flex-container style="display:flex; flex-direction: column; height: 100%;">
                        <div style="display: flex; flex-direction: row; justify-content: space-between">
                            <strong><a href="/user/@cheep.AuthorName">@cheep.AuthorName</a></strong>
                            @if (User.Identity != null && User.Identity.IsAuthenticated)
                            {
                                if (cheep.AuthorName == User.Identity.Name)
                                {
                                    <form method="post" asp-page-handler="Delete" style="display: flex">
                                        <input asp-for="CheepIdForDeletion" type="hidden" value="@cheep.CheepId">
                                        <input type="submit" value="Delete" style="float:right; background:transparent; border-style:none; color:#CC6E6E; cursor:pointer;">
                                    </form>
                                }
                            }
                        </div>
                        <div>@cheep.Text</div>
                        <div style="display: flex; flex-direction: row; justify-content: space-between;">
                            <small>@cheep.DatePosted</small>
                            @if (User.Identity != null && User.Identity.IsAuthenticated)
                            {
                                <button class="textButton" onclick="ReplyToCheep(@cheep.CheepId)">Reply</button>
                            }
                        </div>
                    </flex-container>
                    <div id="reply-@cheep.CheepId" style="display: none;">
                        <form method="post" asp-page-handler="Reply">
                            <input asp-for="Reply.CheepID" type="hidden" value="@cheep.CheepId">
                            <textarea required placeholder="Reply.." asp-for="Reply.Reply"></textarea>
                            <input type="submit" value="Post">
                        </form>
                    </div>
                </li>
            }
        </ul>
    }
    else
    {
        <em>There are no cheeps so far.</em>
    }

    <div style="
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    ">
        @if (Model.HasPreviousPage)
        {
            <a href="/?page=@(Model.CurrentPage - 1)" style="font-size: 20px;">&larr;</a>
        }
        <span style="font-size: 16px;">Page @Model.CurrentPage</span>
        @if (Model.HasNextPage)
        {
            <a href="/?page=@(Model.CurrentPage + 1)" style="font-size: 20px;">&rarr;</a>
        }
    </div>
</div>

<style>
    .textButton {
        border: none;
        background: none;
        padding: 0;
        color: #0a3069;
        text-decoration: underline;
        cursor: pointer;
    }
    
</style>

<script>
    function ReplyToCheep(cheepID) {
        var replySection = document.getElementById("reply-" + cheepID);
        if (replySection.style.display === 'none') { replySection.style.display = 'block'; }
        else { replySection.style.display = 'none'; }
    }
</script>